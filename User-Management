<div id="user-security-page" class="page">
  <div class="container admin-page">
    <div class="page-header">
      <h1>👤 User & Security Management</h1>
      <p>Manage member directory, passwords, and 2FA protocols</p>
    </div>
    
    <div style="display:grid;grid-template-columns:2fr 1fr;gap:24px;margin-bottom:24px">
      <div class="admin-table-card">
        <div class="admin-table-header">
          <h3>📇 Member Directory</h3>
          <input type="text" class="input-field" placeholder="Search members..." style="width:220px;padding:8px 12px;font-size:0.85rem" id="member-search" oninput="filterMemberDirectory()">
        </div>
        <div style="overflow-x:auto">
          <table class="data-table" id="member-table">
            <thead><tr><th>Name</th><th>Email</th><th>Plan</th><th>Joined</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody id="member-tbody"></tbody>
          </table>
        </div>
      </div>
      
      <div class="admin-table-card">
        <div class="admin-table-header">
          <h3>⚡ Quick Actions</h3>
        </div>
        <div style="padding:24px;display:flex;flex-direction:column;gap:12px">
          <button class="btn btn-sm" style="justify-content:flex-start;gap:8px;padding:10px 12px" onclick="openPasswordResetModal()">
            <span class="material-symbols-rounded" style="font-size:18px">lock_reset</span>
            <div style="text-align:left">
              <div style="font-size:0.85rem;font-weight:600">Password Reset</div>
              <div style="font-size:0.75rem;color:var(--text-soft)">Generate reset link</div>
            </div>
          </button>
          <button class="btn btn-sm" style="justify-content:flex-start;gap:8px;padding:10px 12px" onclick="openAccountUnlockModal()">
            <span class="material-symbols-rounded" style="font-size:18px">lock_open</span>
            <div style="text-align:left">
              <div style="font-size:0.85rem;font-weight:600">Unlock Account</div>
              <div style="font-size:0.75rem;color:var(--text-soft)">Remove access restrictions</div>
            </div>
          </button>
          <button class="btn btn-sm" style="justify-content:flex-start;gap:8px;padding:10px 12px" onclick="open2FAManager()">
            <span class="material-symbols-rounded" style="font-size:18px">verified_user</span>
            <div style="text-align:left">
              <div style="font-size:0.85rem;font-weight:600">2FA Management</div>
              <div style="font-size:0.75rem;color:var(--text-soft)">Enforce security</div>
            </div>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
