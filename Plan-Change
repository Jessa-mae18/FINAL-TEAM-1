<!-- File Manager -->
<div class="modal-overlay" id="file-manager-modal">
  <div class="modal-content" style="max-width:720px">
    <div class="modal-header">
      <h2><span class="material-symbols-rounded" style="font-size:22px">folder_open</span> Select Document</h2>
      <button class="modal-close-btn" onclick="closeFileModal()"><span class="material-symbols-rounded">close</span></button>
    </div>
    <div class="modal-body">
      <div class="info-box info mb-20"><span class="material-symbols-rounded" style="font-size:18px;flex-shrink:0;color:var(--accent)">info</span>Select the correct document for each requirement. Your files must be valid and match the expected format.</div>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:20px;text-align:center">
        <div class="file-item" onclick="selectFile('Valid Government ID')">
          <div style="display:flex;justify-content:center;margin-bottom:12px"><div style="width:60px;height:60px;background:var(--gradient-main);border-radius:12px;display:flex;align-items:center;justify-content:center"><span class="material-symbols-rounded" style="font-size:34px;color:white">badge</span></div></div>
          <p style="font-size:0.87rem;color:var(--text);font-weight:600">Valid Government ID.docx</p>
          <p style="font-size:0.75rem;color:var(--text-muted);margin-top:4px">Required: Government ID</p>
        </div>
        <div class="file-item" onclick="selectFile('Proof of Address')">
          <div style="display:flex;justify-content:center;margin-bottom:12px"><div style="width:60px;height:60px;background:var(--gradient-gold);border-radius:12px;display:flex;align-items:center;justify-content:center"><span class="material-symbols-rounded" style="font-size:34px;color:white">home</span></div></div>
          <p style="font-size:0.87rem;color:var(--text);font-weight:600">Proof of Address.pdf</p>
          <p style="font-size:0.75rem;color:var(--text-muted);margin-top:4px">Required: Proof of Address</p>
        </div>
        <div class="file-item" onclick="selectFile('Recent 2x2 Photo')">
          <div style="display:flex;justify-content:center;margin-bottom:12px"><div style="width:60px;height:60px;background:var(--gradient-green);border-radius:12px;display:flex;align-items:center;justify-content:center"><span class="material-symbols-rounded" style="font-size:34px;color:white">portrait</span></div></div>
          <p style="font-size:0.87rem;color:var(--text);font-weight:600">2x2.png</p>
          <p style="font-size:0.75rem;color:var(--text-muted);margin-top:4px">Required: 2x2 Photo</p>
        </div>
        <div class="file-item" onclick="selectFile('Medical Certificate (Recent)')">
          <div style="display:flex;justify-content:center;margin-bottom:12px"><div style="width:60px;height:60px;background:linear-gradient(135deg,#10B981,#34d399);border-radius:12px;display:flex;align-items:center;justify-content:center"><span class="material-symbols-rounded" style="font-size:34px;color:white">medical_information</span></div></div>
          <p style="font-size:0.87rem;color:var(--text);font-weight:600">Medical Certificate.pdf</p>
          <p style="font-size:0.75rem;color:var(--text-muted);margin-top:4px">Required: Medical Certificate (within 6 months)</p>
        </div>
      </div>
    </div>
  </div>
</div>
